# ============================================================
# RAD Vision Academy — Environment Variables
# Copy this file to .env.local and fill in your Supabase project keys
# ============================================================

# --- Supabase Core (REQUIRED) ---
# Find these in your Supabase Dashboard → Project Settings → API
# https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# --- Supabase Server SDK (optional, for edge/serverless functions) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...
SUPABASE_JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json

# --- Formspree (optional) ---
# If set, the contact form POSTs to Formspree. Otherwise Netlify Forms is used.
NEXT_PUBLIC_FORMSPREE_ID=

# ============================================================
# NOTES
# ============================================================
# - NEXT_PUBLIC_* vars are exposed to the browser (safe — anon key only).
# - SUPABASE_SERVICE_ROLE_KEY is SECRET and must NEVER be imported in
#   client code. It bypasses Row Level Security.
# - NEXT_PUBLIC_* vars are INLINED at build time. They MUST be set in
#   both .env.local (local dev) AND your hosting environment (Netlify
#   dashboard → Site settings → Environment variables) before building.
# ============================================================
